{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Game",
      "request": "launch",
      "mainClass": "com.majortom.algorithms.app.snake.Game",
      "projectName": "algorithms-sandbox"
    },
    {
      "type": "java",
      "name": "LinkedList",
      "request": "launch",
      "mainClass": "com.majortom.algorithms.core.basic.LinkedList",
      "projectName": "algorithms-core"
    },
    {
      "type": "java",
      "name": "LauncherMain",
      "request": "launch",
      "mainClass": "com.majortom.algorithms.launcher.LauncherMain",
      "projectName": "algorithms-launcher"
    },
    {
      "type": "java",
      "name": "Run Maze Project",
      "request": "launch",
      "mainClass": "com.majortom.algorithms.App",
      "vmArgs": [
        "-Dprism.order=sw",
        "-Dprism.verbose=true"
      ]
    }
  ]
}
