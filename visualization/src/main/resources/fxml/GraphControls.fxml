<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
  alignment="CENTER_LEFT" spacing="10"
  style="-fx-min-height: 80px; -fx-padding: 0 5;"
  stylesheets="@../style/ui_theme.css">

  <HBox spacing="6" alignment="CENTER_LEFT"
    style="-fx-background-color: rgba(255,255,255,0.03); -fx-padding: 6 8; -fx-background-radius: 4;">
    <TextField fx:id="nodeInputField" prefWidth="62" minWidth="62" styleClass="dark-textfield compact-textfield" />
    <Button fx:id="addBtn" onAction="#handleAddNode" styleClass="btn-ran-purple compact-button" prefWidth="56"
      minWidth="56" />
    <Button fx:id="deleteBtn" onAction="#handleDeleteNode" styleClass="btn-ran-red compact-button" prefWidth="56"
      minWidth="56" />
  </HBox>

  <HBox spacing="4" alignment="CENTER_LEFT">
    <TextField fx:id="fromNodeField" prefWidth="42" minWidth="42" styleClass="dark-textfield compact-textfield"
      promptText="Src" />
    <Label text="→" style="-fx-text-fill: #666666; -fx-font-weight: bold;" />
    <TextField fx:id="toNodeField" prefWidth="42" minWidth="42" styleClass="dark-textfield compact-textfield"
      promptText="Dest" />
    <TextField fx:id="weightField" prefWidth="38" minWidth="38" styleClass="dark-textfield compact-textfield"
      promptText="W" />
    <Button fx:id="linkBtn" onAction="#handleLink" styleClass="btn-ran-gold compact-button" prefWidth="68"
      minWidth="68" />
  </HBox>

  <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 0 4;">
    <Button fx:id="runBtn" onAction="#handleRun"
      styleClass="btn-ran-blue compact-button" prefWidth="96" minWidth="96"
      style="-fx-font-weight: bold; -fx-font-size: 12px;" />
  </HBox>

</HBox>
